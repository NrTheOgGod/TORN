<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TORN - Read Latest Releases</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-[#0b0c0d] text-gray-200 font-sans min-h-screen flex flex-col justify-between scroll-smooth">

  <header class="w-full h-20 bg-[#111214] border-b border-neutral-900 flex justify-center sticky top-0 z-50">
    <div class="w-full max-w-7xl px-6 flex items-center justify-between">
      <a href="/" class="text-2xl font-black text-white tracking-tighter uppercase">
        TO<span class="text-red-600">RN</span>
      </a>
      <nav class="flex space-x-10 text-sm font-bold tracking-widest text-neutral-400">
        <a href="/chapters" class="hover:text-white transition">READ CHAPTERS</a>
        <a href="/" class="hover:text-white transition">LATEST RELEASE</a>
        <a href="#about-us" class="hover:text-white transition">ABOUT US</a>
      </nav>
      <div class="text-neutral-400 hover:text-white cursor-pointer transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707-.707m12.728 0l-.707.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
      </div>
    </div>
  </header>

  <main class="w-full max-w-7xl mx-auto px-6 py-16 flex-grow flex items-center">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center w-full">
      
      <div class="lg:col-span-6 space-y-6 text-center lg:text-left">
        <h1 class="text-5xl md:text-7xl font-serif font-light uppercase tracking-tight text-white leading-tight">
          READ OUR <br>
          <span class="text-red-600 font-bold block mt-2">LATEST</span> 
          RELEASES
        </h1>
      </div>

      <div class="lg:col-span-6 flex justify-center lg:justify-end">
        <% if (typeof latestChapter !== 'undefined' && latestChapter) { %>
          <div class="relative w-full max-w-[480px] aspect-[3/4] bg-neutral-900 rounded border border-neutral-800 overflow-hidden group shadow-2xl">
            <img src="/uploads/covers/hero-cover.jpg" alt="CH <%= latestChapter.chapterNumber %>: <%= latestChapter.title %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-700">
            <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black via-black/70 to-transparent p-6 pt-20">
              <p class="text-white font-serif text-xl tracking-wide">CH <%= latestChapter.chapterNumber %>: <%= latestChapter.title %></p>
              <a href="/read/ch/<%= latestChapter.chapterNumber %>" class="inline-block mt-3 text-xs uppercase tracking-widest font-bold border-b border-red-500 text-red-500 pb-1 hover:text-white hover:border-white transition">Read Chapter Now →</a>
            </div>
          </div>
        <% } else { %>
          <div class="w-full max-w-[480px] text-neutral-500 border border-dashed border-neutral-800 rounded px-12 py-24 text-center">
            No recent chapters published.
          </div>
        <% } %>
      </div>

    </div>
  </main>

  <section id="about-us" class="w-full border-t border-neutral-900 bg-[#0e0f11] py-20 px-6 scroll-mt-20">
    <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      <div class="lg:col-span-4 space-y-4 lg:sticky lg:top-24">
        <h4 class="text-xs font-mono tracking-widest text-red-600 uppercase font-bold">// WHO WE ARE</h4>
        <h2 class="text-4xl md:text-5xl font-serif font-light text-white uppercase tracking-tight leading-tight">
          BEHIND THE <br>
          <span class="font-bold text-white">TORN</span> STORIES
        </h2>
        <p class="text-neutral-400 text-sm leading-relaxed pt-2">
          We are an independent collective of artists, writers, and developer enthusiasts dedicated to building a premium, raw digital comic reading pipeline experience. 
        </p>
      </div>

      <div class="lg:col-span-8 space-y-12">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          
          <div class="border border-neutral-800 bg-[#111214]/50 p-6 rounded space-y-3">
            <div class="w-8 h-8 rounded bg-red-600/10 flex items-center justify-center text-red-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
            </div>
            <h3 class="text-base font-serif font-bold text-white tracking-wide">Original Narrative Craft</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">Pushing creative boundaries to craft gripping universes, heavy ink styling, and sequential artwork across multi-chapter timelines.</p>
          </div>

          <div class="border border-neutral-800 bg-[#111214]/50 p-6 rounded space-y-3">
            <div class="w-8 h-8 rounded bg-red-600/10 flex items-center justify-center text-red-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="text-base font-serif font-bold text-white tracking-wide">High Performance Pipeline</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">Engineered with asset lazy-loading parameters to ensure uninterrupted downward-strip scrolling with absolute peak performance optimization.</p>
          </div>

        </div>

        <div class="border-t border-neutral-900 pt-8 grid grid-cols-3 gap-4 text-center sm:text-left">
          <div>
            <p class="text-3xl md:text-4xl font-mono font-bold text-white tracking-tight">03</p>
            <p class="text-[10px] font-mono tracking-widest text-neutral-600 uppercase mt-1">Active Series</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-mono font-bold text-red-600 tracking-tight">25K+</p>
            <p class="text-[10px] font-mono tracking-widest text-neutral-600 uppercase mt-1">Monthly Readers</p>
          </div>
          <div>
            <p class="text-3xl md:text-4xl font-mono font-bold text-white tracking-tight">100%</p>
            <p class="text-[10px] font-mono tracking-widest text-neutral-600 uppercase mt-1">Creator Owned</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <footer class="w-full border-t border-neutral-950 bg-[#090a0b] py-6 text-center text-xs text-neutral-600">
    &copy; 2026 TORN COMICS. All Rights Reserved.
  </footer>

</body>
</html>