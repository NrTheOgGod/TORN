<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TORN - CH <%= chapter.chapterNumber %>: <%= chapter.title %></title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-[#050506] text-white font-sans min-h-screen flex flex-col">

  <div class="sticky top-0 z-50 w-full bg-[#111214]/90 backdrop-blur-md border-b border-neutral-900 px-6 py-4 flex justify-between items-center shadow-lg">
    <a href="/chapters" class="text-xs font-bold uppercase tracking-widest text-neutral-400 hover:text-white transition flex items-center gap-2">
      ← Back to Chapters
    </a>
    <h2 class="text-xs font-mono tracking-widest uppercase text-neutral-400">
      READING: <span class="text-white font-sans font-bold">CHAPTER <%= chapter.chapterNumber %> <%= chapter.title ? '- ' + chapter.title : '' %></span>
    </h2>
    <% if (chapter.downloadUrl) { %>
      <a href="/download/ch/<%= chapter.chapterNumber %>" class="text-xs bg-red-600 px-4 py-2 rounded font-bold tracking-wider hover:bg-red-700 transition uppercase shadow-md">
        Download ZIP
      </a>
    <% } else { %>
      <div class="w-20"></div>
    <% } %>
  </div>

  <main class="flex flex-col items-center w-full max-w-[800px] mx-auto bg-[#000000] shadow-2xl flex-grow">
    <% if (chapter.pages && chapter.pages.length > 0) { %>
      <% chapter.pages.forEach((pagePath, index) => { %>
        <img 
          src="<%= pagePath %>" 
          alt="Page <%= index + 1 %>" 
          class="w-full h-auto select-none pointer-events-none mb-1 block" 
          loading="<%= index === 0 ? 'eager' : 'lazy' %>"
        >
      <% }) %>
    <% } else { %>
      <div class="py-24 text-center text-neutral-500 font-mono tracking-wide">
        No scanned pages found loaded for this resource record node.
      </div>
    <% } %>
  </main>

  <section class="w-full bg-[#111214] py-16 flex flex-col items-center border-t border-neutral-900 text-center px-6">
    <h3 class="text-2xl font-serif mb-2 tracking-wide">You've reached the end of Chapter <%= chapter.chapterNumber %></h3>
    <p class="text-sm text-neutral-500 mb-6 max-w-sm">Support the creators by sharing the link or checking out our community pages.</p>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/chapters" class="bg-white text-black px-8 py-3 rounded text-sm font-bold tracking-widest hover:bg-neutral-200 transition uppercase">
        Chapter Directory
      </a>
      <% if (chapter.downloadUrl) { %>
        <a href="/download/ch/<%= chapter.chapterNumber %>" class="bg-neutral-900 border border-neutral-800 text-neutral-300 px-8 py-3 rounded text-sm font-bold tracking-widest hover:bg-neutral-800 transition uppercase">
          Download Offline Copy
        </a>
      <% } %>
    </div>
  </section>

</body>
</html>