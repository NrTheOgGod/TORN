<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TORN - Read All Chapters</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-[#0b0c0d] text-gray-200 font-sans min-h-screen flex flex-col">

  <header class="w-full h-20 bg-[#111214] border-b border-neutral-900 flex justify-center sticky top-0 z-50">
    <div class="w-full max-w-7xl px-6 flex items-center justify-between">
      <a href="/" class="text-2xl font-black text-white tracking-tighter uppercase">TO<span class="text-red-600">RN</span></a>
      <nav class="flex space-x-10 text-sm font-bold tracking-widest text-neutral-400">
        <a href="/chapters" class="text-red-500 transition">READ CHAPTERS</a>
        <a href="/" class="hover:text-white transition">LATEST RELEASE</a>
        <a href="#" class="hover:text-white transition">ABOUT US</a>
      </nav>
      <div class="text-neutral-400 hover:text-white cursor-pointer transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707-.707m12.728 0l-.707.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
      </div>
    </div>
  </header>

  <main class="w-full max-w-7xl mx-auto px-6 py-12 flex-grow">
    <h2 class="text-3xl font-serif tracking-widest uppercase text-center text-white mb-12 border-b border-neutral-900 pb-4">READ ALL CHAPTERS</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      
      <% if (typeof chapters !== 'undefined' && chapters && chapters.length > 0) { %>
        <% chapters.forEach(chapter => { %>
          <div class="bg-[#111214] border border-neutral-800 rounded overflow-hidden flex flex-col justify-between group hover:border-neutral-700 transition">
            <div class="relative w-full aspect-[3/4] bg-neutral-950 overflow-hidden">
              <img src="<%= (chapter.pages && chapter.pages.length > 0) ? chapter.pages[0] : '/uploads/covers/hero-cover.jpg' %>" alt="<%= chapter.title %> preview" class="w-full h-full object-cover group-hover:scale-102 transition duration-500">
            </div>
            <div class="p-5 space-y-4">
              <div>
                <h4 class="text-sm font-mono tracking-wider text-neutral-500 uppercase">CH <%= chapter.chapterNumber %></h4>
                <h3 class="text-lg font-serif font-bold text-white tracking-wide mt-0.5 truncate"><%= chapter.title || 'UNTITLED' %></h3>
              </div>
              <div class="flex items-center space-x-2">
                <a href="/read/ch/<%= chapter.chapterNumber %>" class="flex-grow text-center text-xs font-bold bg-neutral-800 text-white py-2.5 rounded tracking-widest hover:bg-white hover:text-black transition">READ</a>
                <% if (chapter.downloadUrl) { %>
                  <a href="/download/ch/<%= chapter.chapterNumber %>" class="p-2 bg-neutral-900 border border-neutral-800 rounded hover:bg-neutral-800 text-neutral-400 hover:text-white transition" title="Download Zip File">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full py-16 text-center text-neutral-500 border border-dashed border-neutral-800 rounded">
          No records discovered in the collection space yet.
        </div>
      <% } %>

      <div class="bg-[#111214]/40 border border-dashed border-neutral-800 rounded overflow-hidden flex flex-col justify-between">
        <div class="relative w-full aspect-[3/4] bg-neutral-950/20 flex flex-col items-center justify-center p-6 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-neutral-700 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
          <h4 class="text-sm font-mono tracking-wider text-neutral-600 uppercase">CH ..</h4>
          <h3 class="text-base font-serif font-bold text-neutral-500 tracking-wide mt-1">COMING SOON</h3>
        </div>
        <div class="p-5">
          <button disabled class="w-full text-center text-xs font-bold bg-neutral-900 text-neutral-700 py-2.5 rounded tracking-widest cursor-not-allowed">LOCKED</button>
        </div>
      </div>

    </div>
  </main>

  <footer class="w-full border-t border-neutral-950 bg-[#090a0b] py-6 text-center text-xs text-neutral-600">
    &copy; 2026 TORN COMICS. All Rights Reserved.
  </footer>

</body>
</html>